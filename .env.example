# ⚠️ Este arquivo é apenas para uso laboratorial/educacional.
# Em ambientes produtivos, utilize Azure Key Vault, Managed Identity
# ou outro mecanismo seguro para gerenciar credenciais.

# Azure OpenAI
AZURE_OPENAI_BASE_URL=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_MODEL_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_API_KEY=<your-api-key>

# (Opcional)
# KEY_VAULT_URL=https://<your-keyvault-name>.vault.azure.net/
# MAX_FILE_SIZE_MB=2
